using System;
using System.Collections.Generic;
using System.Linq;
using CommandSystem;
using Exiled.API.Features;
using RemoteAdmin;

namespace CallAdmin.Commands
{
    [CommandHandler(typeof(ClientCommandHandler))]
    public sealed class CallCommand : ICommand
    {
        public string Command => "call";
        public string[] Aliases => new[] { "calladmin" };
        public string Description => "Викликати адміна. Використання: .call [причина]";

        private static readonly Dictionary<string, DateTime> _cooldowns = new();

        public bool Execute(ArraySegment<string> arguments, ICommandSender sender, out string response)
        {
            if (sender is not PlayerCommandSender playerSender)
            {
                response = "Тільки для гравців!";
                return false;
            }

            Player player = Player.Get(playerSender.ReferenceHub);
            if (player is null)
            {
                response = "Помилка гравця.";
                return false;
            }

            Config cfg = Plugin.Instance.Config;

            if (_cooldowns.TryGetValue(player.UserId, out DateTime expires))
            {
                double remaining = (expires - DateTime.UtcNow).TotalSeconds;
                if (remaining > 0)
                {
                    response = cfg.CooldownMessage.Replace("{seconds}", Math.Ceiling(remaining).ToString());
                    return false;
                }
            }

            string reason = arguments.Count > 0 ? string.Join(" ", arguments) : "Без причини";

            List<Player> admins = Player.List.Where(p => p.RemoteAdminAccess && !p.IsNPC).ToList();

            if (admins.Count == 0)
            {
                response = cfg.NoAdminsOnline;
                return false;
            }

            string broadcast = cfg.AdminBroadcast
                .Replace("{nick}", player.Nickname)
                .Replace("{id}", player.Id.ToString())
                .Replace("{reason}", reason);

            foreach (Player admin in admins)
            {
                admin.Broadcast(cfg.BroadcastDuration, broadcast, Broadcast.BroadcastFlags.Normal, cfg.OverrideBroadcast);
                admin.SendConsoleMessage($"[CallAdmin] {player.Nickname} (ID: {player.Id}) | Причина: {reason}", "yellow");
            }

            Log.Info($"[CallAdmin] {player.Nickname} (ID: {player.Id}) викликав адміна. Причина: {reason}");
            _cooldowns[player.UserId] = DateTime.UtcNow.AddSeconds(cfg.CooldownSeconds);

            response = cfg.CallerSuccess;
            return true;
        }
    }
}
